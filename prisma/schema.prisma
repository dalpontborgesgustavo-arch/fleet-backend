generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  name       String
  password   String
  role       String
  tipoFrota  String?
  createdAt  DateTime    @default(now())
  checklists Checklist[]
}

model Checklist {
  id        String          @id @default(uuid())
  title     String
  vehicleId String?
  month     Int
  year      Int
  status    String
  createdBy String
  createdAt DateTime        @default(now())
  items     ChecklistItem[]
  user      User            @relation(fields: [createdBy], references: [id])
}

model ChecklistItem {
  id          String    @id @default(uuid())
  checklistId String
  label       String
  ok          Boolean
  createdAt   DateTime  @default(now())
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
}
